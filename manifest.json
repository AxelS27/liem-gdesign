{
  "manifest_version": 3,
  "name": "Liem gDesign",
  "version": "0.1.0",
  "description": "Extract design DNA (information architecture, typography, color palettes, and animations) from any website into a structured DESIGN.md file.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
